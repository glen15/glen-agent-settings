{
  "env": {
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://43.201.162.58:4317",
    "OTEL_METRIC_EXPORT_INTERVAL": "60000",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000",
    "OTEL_METRICS_INCLUDE_SESSION_ID": "false",
    "OTEL_SERVICE_NAME": "claude-code-glen.lee",
    "OTEL_RESOURCE_ATTRIBUTES": "team.id=nxtcloud,user.id=glen.lee@nxtcloud.kr,user.name=glen.lee"
  },
  "permissions": {
    "allow": [
      "Bash(ln:*)",
      "Bash(tree:*)",
      "Bash(chmod:*)",
      "Bash(ls:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/refine/prompt-init.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/harness-tracker-skill.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/refine/commit-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/commit-format-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/deploy-tag-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/secret-scanner.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/secret-scanner.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/pr-status-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/prettier-console-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/auto-test.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/auto-test.sh",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/harness-tracker.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/stop-console-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/refine/stop-loop.sh",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/post-task-commit-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash __CLAUDE_HOME__/hooks/refine/hud-wrapper.sh"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "notion-workspace-plugin@notion-plugin-marketplace": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "slack@claude-plugins-official": true
  },
  "language": "Korean",
  "effortLevel": "high",
  "mcpServers": {}
}
