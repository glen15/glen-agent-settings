# glen-agent-settings — 개인화 설정
# 이 파일을 .env.local로 복사한 후 값을 채워주세요.
# cp .env.example .env.local
#
# build.sh 실행 시 src/ 내 __PLACEHOLDER__ 토큰이 이 값으로 치환됩니다.

# ── OpenTelemetry ──
# Claude Code 텔레메트리 수집 엔드포인트 (gRPC)
OTEL_ENDPOINT=http://localhost:4317

# 서비스 이름 (텔레메트리 식별용)
OTEL_SERVICE_NAME=claude-code-user

# 리소스 속성 (팀/사용자 식별)
OTEL_RESOURCE_ATTRIBUTES=team.id=default,user.id=user,user.name=user

# ── Contents Creator ──
# glen-contents-creator 프로젝트 경로 (/create-content, /image 스킬에서 사용)
CONTENTS_CREATOR_DIR=${HOME}/glen-contents-creator
